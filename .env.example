# Capital.com DEMO credentials.
# Copy this file to `.env` and fill in your demo account values.
# NEVER commit `.env`. NEVER hardcode these values in source or config files.

# API key created in the Capital.com platform (Settings -> API integrations).
CAPITAL_API_KEY=

# Account identifier (the email/login used for the demo account).
CAPITAL_IDENTIFIER=

# The custom API password set when creating the API key
# (this is NOT your account login password).
CAPITAL_API_PASSWORD=

# Operating mode override (optional).
# Allowed: BACKTEST | SHADOW | CAPITAL_DEMO | LIVE_DISABLED
# Live trading cannot be enabled in this version.
ORCHESTRATOR_MODE=CAPITAL_DEMO

# Log level (optional): DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
